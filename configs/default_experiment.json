{
  "dataset": {
    "categories": ["bottle"],
    "root": "data/mvtec_ad"
  },
  "model": {
    "model_type": "normal_stats",
    "pixel_quantile": 0.995,
    "score_quantile": 0.995,
    "topk_ratio": 0.02,
    "smoothing_sigma": 0.0
  },
  "postprocessing": {
    "closing_iterations": 1,
    "enabled": true,
    "min_component_area_px": 32,
    "opening_iterations": 1
  },
  "preprocessing": {
    "grayscale": true,
    "image_size": [256, 256]
  },
  "rules": {
    "border_margin_px": 4,
    "distributed_region_count": 3,
    "elongated_aspect_ratio": 3.0,
    "min_region_area_px": 32,
    "severity_high_area_fraction": 0.05,
    "severity_medium_area_fraction": 0.015,
    "thin_fill_ratio": 0.15
  },
  "runtime": {
    "experiment_name": "default_bottle_stats",
    "max_qualitative_examples_per_category": 0,
    "save_per_sample_records": true,
    "save_qualitative_examples": false,
    "seed": 7
  }
}
